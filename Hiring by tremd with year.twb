    <worksheet name='Task 4'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Task 4  - Qualification Drilldown Map - No Records Matching All Constraints</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='job_descriptions' name='federated.1kamcjr1dyg5px11zxqd911uyxcs' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.1kamcjr1dyg5px11zxqd911uyxcs'>
            <column caption='Min Salary' datatype='integer' default-format='c&quot;$&quot;#,##0' name='[Calculation_1703180897017869]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;LEFT([Salary Range], FIND([Salary Range], &quot;-&quot;) - 1),&#13;&#10;&quot;$&quot;,&quot;&quot;&#13;&#10;),&#13;&#10;&quot;K&quot;,&quot;&quot;&#13;&#10;)&#13;&#10;) * 1000' />
            </column>
            <column caption='Job starts D' datatype='boolean' name='[Calculation_1895596853968898]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([Job Title],1) = &quot;D&quot;' />
            </column>
            <column caption='Cont A' datatype='boolean' name='[Calculation_1895596854452227]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([Contact Person],1) = &quot;A&quot;' />
            </column>
            <column caption='Show 3 - 6 PM' datatype='boolean' name='[Calculation_1895596856025092]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15&#13;&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt; 18' />
            </column>
            <column datatype='integer' name='[Company Size]' role='measure' type='quantitative' />
            <column datatype='string' name='[Company]' role='dimension' type='nominal' />
            <column datatype='string' name='[Contact Person]' role='dimension' type='nominal' />
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='string' name='[Job Portal]' role='dimension' type='nominal' />
            <column datatype='string' name='[Job Title]' role='dimension' type='nominal' />
            <column datatype='string' name='[Preference]' role='dimension' type='nominal' />
            <column datatype='string' name='[Qualifications]' role='dimension' type='nominal' />
            <column datatype='string' datatype-customized='true' name='[Salary Range]' role='dimension' type='nominal' />
            <column datatype='string' name='[Work Type]' role='dimension' type='nominal' />
            <column-instance column='[Salary Range]' derivation='Attribute' name='[attr:Salary Range:nk]' pivot='key' type='nominal' />
