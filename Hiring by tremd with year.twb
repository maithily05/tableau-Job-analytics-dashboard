      <aliases enabled='yes' />
      <column caption='Asia Not I Filter ' datatype='string' name='[Calculation_1158648796442624]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] IN (&#13;&#10;&quot;China&quot;,&quot;Japan&quot;,&quot;South Korea&quot;,&quot;Thailand&quot;,&quot;Malaysia&quot;,&#13;&#10;&quot;Singapore&quot;,&quot;Indonesia&quot;,&quot;Philippines&quot;,&quot;Vietnam&quot;,&#13;&#10;&quot;Bangladesh&quot;,&quot;Nepal&quot;,&quot;Sri Lanka&quot;,&quot;Pakistan&quot;&#13;&#10;)&#13;&#10;AND NOT STARTSWITH([Country],&quot;I&quot;)&#13;&#10;THEN &quot;Valid&quot;&#13;&#10;END' />
      </column>
      <column caption='Min 2 Vowels' datatype='boolean' name='[Calculation_1158648797028353]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN(REGEXP_REPLACE(LOWER([Company]), &quot;[^aeiou]&quot;, &quot;&quot;)) &gt;= 2' />
      </column>
      <column caption='Time Visibility' datatype='string' name='[Calculation_1158648799854594]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, NOW()) &gt;= 15 &#13;&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt; 17&#13;&#10;THEN &quot;Show&quot;&#13;&#10;ELSE &quot;Hide&quot;&#13;&#10;END' />
      </column>
      <column caption='Odd Month' datatype='string' name='[Calculation_1703180885958657]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([Job Posting Date]) % 2 = 1 &#13;&#10;THEN &quot;Odd Month&quot; &#13;&#10;ELSE &quot;Even Month&quot; &#13;&#10;END' />
      </column>
      <column caption='Country Not ABCD' datatype='boolean' name='[Calculation_1703180887625730]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT LEFT([Country],1) IN (&quot;A&quot;,&quot;B&quot;,&quot;C&quot;,&quot;D&quot;)' />
      </column>
      <column caption='Short Single Word Title ' datatype='boolean' name='[Calculation_1703180887810051]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN([Job Title]) &lt; 10&#13;&#10;AND NOT CONTAINS([Job Title],&quot; &quot;)' />
      </column>
      <column caption='Company Has 2+ Vowels' datatype='boolean' name='[Calculation_1703180887949316]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN([Company]) -&#13;&#10;LEN(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;REPLACE(LOWER([Company]),&#13;&#10;&quot;a&quot;,&quot;&quot;),&#13;&#10;&quot;e&quot;,&quot;&quot;),&#13;&#10;&quot;i&quot;,&quot;&quot;),&#13;&#10;&quot;o&quot;,&quot;&quot;),&#13;&#10;&quot;u&quot;,&quot;&quot;)&#13;&#10;)&#13;&#10;&gt;= 2' />
      </column>
      <column caption='Contact Ends With Vowel' datatype='boolean' name='[Calculation_1703180890144773]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(LOWER([Contact Person]),1) &#13;&#10;IN (&quot;a&quot;,&quot;e&quot;,&quot;i&quot;,&quot;o&quot;,&quot;u&quot;)' />
      </column>
      <column caption='Contact Contains e' datatype='boolean' name='[Calculation_1703180890275846]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS(LOWER([Contact Person]),&quot;e&quot;)' />
      </column>
      <column caption='Show Between 3 and 5 PM' datatype='boolean' name='[Calculation_1703180890394631]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='TRUE' />
      </column>
      <column caption='Country Not Starting With I' datatype='boolean' name='[Calculation_1703180891521032]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Country],1) != &quot;I&quot;' />
      </column>
      <column caption='Job Title Starts With D' datatype='boolean' name='[Calculation_1703180891656201]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Job Title],1) = &quot;D&quot;' />
      </column>
      <column caption='Contact Starts With A' datatype='boolean' name='[Calculation_1703180891787274]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Contact Person],1) = &quot;A&quot;' />
      </column>
      <column caption='Company Name &gt; 8 Characters' datatype='boolean' name='[Calculation_1703180891947019]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN([Company]) &gt; 8' />
      </column>
      <column caption='Count' datatype='integer' name='[Calculation_1703180894085132]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Min Salary' datatype='integer' default-format='c&quot;$&quot;#,##0' name='[Calculation_1703180897017869]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#13;&#10;REPLACE(&#13;&#10;REPLACE(&#13;&#10;LEFT([Salary Range], FIND([Salary Range], &quot;-&quot;) - 1),&#13;&#10;&quot;$&quot;,&quot;&quot;&#13;&#10;),&#13;&#10;&quot;K&quot;,&quot;&quot;&#13;&#10;)&#13;&#10;) * 1000' />
      </column>
      <column caption='Max Salary' datatype='integer' default-format='c&quot;$&quot;#,##0' name='[Calculation_1703180899135502]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#13;&#10;    REPLACE(&#13;&#10;        REPLACE(&#13;&#10;            RIGHT([Salary Range],&#13;&#10;            LEN([Salary Range]) - FIND([Salary Range], &quot;-&quot;)&#13;&#10;            ),&#13;&#10;        &quot;$&quot;,&quot;&quot;),&#13;&#10;    &quot;K&quot;,&quot;&quot;)&#13;&#10;) * 1000' />
      </column>
      <column caption='Clean Experience' datatype='integer' name='[Calculation_1703180906926096]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='INT(TRIM(SPLIT([Experience], &quot;to&quot;, 1)))' />
      </column>
      <column caption='Even Experience' datatype='string' name='[Calculation_1703180914126866]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1703180906926096] % 2 = 0&#13;&#10;THEN &quot;Even&quot;&#13;&#10;ELSE &quot;Odd&quot;&#13;&#10;END' />
      </column>
      <column caption='Country Not C ' datatype='boolean' name='[Calculation_1895596847988736]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Country],1) != &quot;C&quot;' />
      </column>
      <column caption='Contact Ends With Vowels' datatype='boolean' name='[Calculation_1895596849963009]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(LOWER([Contact Person]),1) IN (&quot;a&quot;,&quot;e&quot;,&quot;i&quot;,&quot;o&quot;,&quot;u&quot;)' />
      </column>
      <column caption='Job starts D' datatype='boolean' name='[Calculation_1895596853968898]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Job Title],1) = &quot;D&quot;' />
      </column>
      <column caption='Cont A' datatype='boolean' name='[Calculation_1895596854452227]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Contact Person],1) = &quot;A&quot;' />
      </column>
      <column caption='Show 3 - 6 PM' datatype='boolean' name='[Calculation_1895596856025092]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15&#13;&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt; 18' />
      </column>
      <column caption='Min Experience' datatype='integer' name='[Calculation_1895596860096518]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(LEFT([Experience], FIND(&quot; &quot;, [Experience]) - 1))' />
      </column>
      <column caption='Loc Not Blank ' datatype='boolean' name='[Calculation_1895596862742535]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN(TRIM([location])) &gt; 0' />
      </column>
