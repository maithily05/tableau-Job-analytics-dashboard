    <worksheet name='Task 1'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Task 1 – Preference vs Work Type (Intern)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='job_descriptions' name='federated.1kamcjr1dyg5px11zxqd911uyxcs' />
          </datasources>
          <datasource-dependencies datasource='federated.1kamcjr1dyg5px11zxqd911uyxcs'>
            <column caption='Odd Month' datatype='string' name='[Calculation_1703180885958657]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF MONTH([Job Posting Date]) % 2 = 1 &#13;&#10;THEN &quot;Odd Month&quot; &#13;&#10;ELSE &quot;Even Month&quot; &#13;&#10;END' />
            </column>
            <column caption='Country Not ABCD' datatype='boolean' name='[Calculation_1703180887625730]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT LEFT([Country],1) IN (&quot;A&quot;,&quot;B&quot;,&quot;C&quot;,&quot;D&quot;)' />
            </column>
            <column caption='Short Single Word Title ' datatype='boolean' name='[Calculation_1703180887810051]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN([Job Title]) &lt; 10&#13;&#10;AND NOT CONTAINS([Job Title],&quot; &quot;)' />
            </column>
            <column caption='Show Between 3 and 5 PM' datatype='boolean' name='[Calculation_1703180890394631]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='TRUE' />
            </column>
            <column caption='Max Salary' datatype='integer' default-format='c&quot;$&quot;#,##0' name='[Calculation_1703180899135502]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(&#13;&#10;    REPLACE(&#13;&#10;        REPLACE(&#13;&#10;            RIGHT([Salary Range],&#13;&#10;            LEN([Salary Range]) - FIND([Salary Range], &quot;-&quot;)&#13;&#10;            ),&#13;&#10;        &quot;$&quot;,&quot;&quot;),&#13;&#10;    &quot;K&quot;,&quot;&quot;)&#13;&#10;) * 1000' />
            </column>
            <column caption='Clean Experience' datatype='integer' name='[Calculation_1703180906926096]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='INT(TRIM(SPLIT([Experience], &quot;to&quot;, 1)))' />
            </column>
            <column caption='Even Experience' datatype='string' name='[Calculation_1703180914126866]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1703180906926096] % 2 = 0&#13;&#10;THEN &quot;Even&quot;&#13;&#10;ELSE &quot;Odd&quot;&#13;&#10;END' />
            </column>
            <column datatype='integer' name='[Company Size]' role='measure' type='quantitative' />
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='string' datatype-customized='true' name='[Experience]' role='dimension' type='nominal' />
            <column datatype='date' name='[Job Posting Date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Job Title]' role='dimension' type='nominal' />
            <column datatype='string' name='[Preference]' role='dimension' type='nominal' />
            <column datatype='string' datatype-customized='true' name='[Salary Range]' role='dimension' type='nominal' />
            <column datatype='string' name='[Work Type]' role='dimension' type='nominal' />
            <column-instance column='[Preference]' derivation='Count' name='[cnt:Preference:qk]' pivot='key' type='quantitative' />
            <column aggregation='Avg' caption='Latitude' datatype='real' name='[latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
            <column-instance column='[Calculation_1703180885958657]' derivation='None' name='[none:Calculation_1703180885958657:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1703180887625730]' derivation='None' name='[none:Calculation_1703180887625730:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1703180887810051]' derivation='None' name='[none:Calculation_1703180887810051:nk]' pivot='key' type='nominal' />
